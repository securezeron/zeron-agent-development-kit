# ZAK (Zeron Agentic Kit) — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# ── Edition ───────────────────────────────────────────────────────────────────
# Controls which agent domains are available (open-source: 4 domains, enterprise: 22)
ZAK_EDITION=open-source

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: openai | anthropic | google | local | mock
LLM_PROVIDER=openai
# Model identifier (provider-specific defaults shown below)
LLM_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_API_KEY=

# Ollama (local LLM — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Generic fallback (used if provider-specific key is not set)
LLM_API_KEY=

# ── Graph Backend ────────────────────────────────────────────────────────────
# Backend: memory (default, no deps) | memgraph (requires Docker + neo4j package)
ZAK_GRAPH_BACKEND=memory

# Memgraph connection (only needed when ZAK_GRAPH_BACKEND=memgraph)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=
